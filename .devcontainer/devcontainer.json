{
  "name": "plexdb",
  "dockerComposeFile": "docker-compose.yml",
  "service": "plexdb",
  "workspaceFolder": "/app",
  "remoteUser": "vscode",
  "shutdownAction": "stopCompose",
  "remoteEnv": {
    // Layer 1 – first pass at clearing VS Code escape vectors.
    // VS Code re-injects some of these for its own processes; the security-harden.sh
    // script sourced from .bashrc (layer 2) is the primary defence.
    "SSH_AUTH_SOCK": "",
    "GPG_AGENT_INFO": "",
    "BROWSER": "",
    "VSCODE_IPC_HOOK_CLI": null,
    "VSCODE_GIT_IPC_HANDLE": null,
    "GIT_ASKPASS": null,
    "VSCODE_GIT_ASKPASS_MAIN": null,
    "VSCODE_GIT_ASKPASS_NODE": null,
    "VSCODE_GIT_ASKPASS_EXTRA_ARGS": null,
    "REMOTE_CONTAINERS_IPC": null,
    "REMOTE_CONTAINERS_SOCKETS": null,
    "REMOTE_CONTAINERS_DISPLAY_SOCK": null,
    "WAYLAND_DISPLAY": null
  },
  // Runs on the host before the container starts. Generates per-worktree .env vars and
  // ensures credential files exist as regular files (Docker creates directories otherwise).
  "initializeCommand": "bash -c 'mkdir -p .devcontainer && echo \"WORKTREE_NAME=$(basename \"$PWD\")\" > .devcontainer/.env && echo \"HOST_UID=$(id -u)\" >> .devcontainer/.env && echo \"HOST_GID=$(id -g)\" >> .devcontainer/.env'",
  // Layer 3a – delete early sockets (SSH auth, remote-containers) created before VS Code attaches.
  "postStartCommand": "find /tmp -maxdepth 2 \\( -name 'vscode-ssh-auth-*.sock' -o -name 'vscode-remote-containers-ipc-*.sock' -o -name 'vscode-remote-containers-*.js' \\) -delete 2>/dev/null || true",
  // Layer 3b – the background socket cleanup loop lives in docker-compose.yml command
  // because postAttachCommand is unreliable for long-running background processes.
  "customizations": {
    "vscode": {
      "settings": {
        // Disable credential injection – prevents VS Code from forwarding host Git credentials
        "dev.containers.dockerCredentialHelper": false,
        "dev.containers.copyGitConfig": false,
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.automationProfile.linux": {
          "path": "/bin/bash"
        },
        "terminal.integrated.profiles.linux": {
          "bash": { "path": "/bin/bash" }
        },
        // clangd uses the compile_commands.json generated by cmake
        "clangd.arguments": [
          "--compile-commands-dir=${workspaceFolder}/build",
          "--background-index",
          "--clang-tidy"
        ]
      },
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-azuretools.vscode-docker",
        "anthropic.claude-code",
        "github.copilot"
      ]
    }
  }
}
