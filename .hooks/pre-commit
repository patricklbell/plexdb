#!/usr/bin/env bash
set -euo pipefail

all_files=false

case "${1:-}" in
    --all)
        all_files=true
        ;;
    "" )
        ;;
    *)
        echo "Usage: $0 [--all]"
        exit 1
        ;;
esac

if $all_files; then
    files=$(git ls-files \
        | grep -E '\.(cpp|cppm|h|hpp)$' \
        | grep -Ev '(third_party/|/tools/)' \
        || true)
else
    files=$(git diff --cached --name-only --diff-filter=ACM \
        | grep -E '\.(cpp|cppm|h|hpp)$' \
        | grep -Ev '(third_party/|/tools/)' \
        || true)
fi

[[ -z "$files" ]] && exit 0

bad=()
while IFS= read -r f; do
    if ! clang-format-19 --dry-run --Werror "$f" 2>/dev/null; then
        bad+=("$f")
    fi
done <<< "$files"

if [[ ${#bad[@]} -gt 0 ]]; then
    if $all_files; then
        echo "clang-format-19: the following tracked files need formatting:"
    else
        echo "clang-format-19: the following staged files need formatting:"
    fi

    printf '  %s\n' "${bad[@]}"
    echo ""
    echo "  Run: clang-format-19 -i ${bad[*]}"
    exit 1
fi
